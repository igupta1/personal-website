# Repo-root env documentation. These vars must be set in the Vercel project
# environment (Vercel dashboard → Settings → Environment Variables).
# This file is for reference only; never commit a populated .env / .env.local.

# Vercel Blob token. Auto-set when you enable Vercel Blob storage on the project.
BLOB_READ_WRITE_TOKEN=

# Shared secret between api/upload-leads.js and the pipeline's daily_run.py.
# Generate via: openssl rand -hex 32
LEADS_UPLOAD_API_KEY=
