# System B — outreach engine. Template. Copy to system_b/.env and fill in.
# (system_b/.env is gitignored; this template is safe to commit.)

# Airtable — token needs schema.bases:write + data.records:read/write scopes
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=

# OpenAI (ChatGPT) — research + copy steps (M2/M3); not needed for M0/M1
OPENAI_API_KEY=

# System A (the lead scraper) base URL — client appends /api/leads etc.
SCRAPER_BASE_URL=
