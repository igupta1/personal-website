# Copy to pipeline/.env and fill in real values. Never commit .env.

# LLM keys
OPENAI_API_KEY=
GEMINI_API_KEY=

# Job board APIs (free tier, optional)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Upload endpoint — for `daily_run.py --upload`. The URL points at the
# Vercel preview / production deployment of api/upload-leads.js. The API
# key is the same value set on the Vercel side as LEADS_UPLOAD_API_KEY.
LEADS_UPLOAD_URL=
LEADS_UPLOAD_API_KEY=
