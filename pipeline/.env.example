# Copy to pipeline/.env and fill in real values. Never commit .env.

# LLM keys
OPENAI_API_KEY=
GEMINI_API_KEY=

# Job board APIs (free tier, optional)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# OpenCorporates Search API (optional). Without a key, the free
# public tier rate-limits the new-business-filings source heavily —
# fine for demos, painful for nightly pulls. Apply at
# https://opencorporates.com/api_accounts/new for higher limits.
OPENCORPORATES_API_KEY=

# Upload endpoint — for `daily_run.py --upload`. The URL points at the
# Vercel preview / production deployment of api/upload-leads.js. The API
# key is the same value set on the Vercel side as LEADS_UPLOAD_API_KEY.
LEADS_UPLOAD_URL=
LEADS_UPLOAD_API_KEY=
